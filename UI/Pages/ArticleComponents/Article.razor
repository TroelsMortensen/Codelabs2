@page "/Article/{owner}/{*tutorialsname}"
@using MdToHtmlConversion.Models.Segments
@using MdToHtmlConversion.Models.Segments.Quiz
@using UI.Pages.QuizComponents.SingleChoiceQuiz
@using UI.Pages.QuizComponents.MultipleChoiceQuiz
@using UI.Pages.QuizComponents.FlashCardSet
@using UI.Pages.QuizComponents.ExpandableDetails

<div>
</div>
<div class="header-container">
    <i class="fa fa-home home-link" @onclick='() => NavMgr.NavigateTo(NavMgr.BaseUri)'></i>
    <h1>@CleanedTutorialsName</h1>
</div>
@if (pages.Count == 0)
{
    <h2>Loading article..</h2>
}
else
{
    <div class="layout" @onclick="CloseDropdown">
        <div class="steps-container steps-left">
            @for (int i = 0; i < pages.Count; i++)
            {
                int idx = i;
                <div class="step @(currentPage == pages[i] ? "active" : "")" @onclick="() => GoToPage(idx)">
                    @pages[i].Name
                </div>
            }
        </div>

        <div class="steps-dropdown" @onclick="CloseDropdown">
            <div class="burger-menu" @onclick="ToggleDropdown" @onclick:stopPropagation>
                <i class="fa fa-bars"></i>
            </div>
            <ul class="dropdown-menu" style="display: @(isDropdownVisible ? "block" : "none");"
                @onclick:stopPropagation>
                @for (int i = 0; i < pages.Count; i++)
                {
                    int idx = i;
                    <li class="dropdown-item" @onclick="() => GoToPage(idx)">
                        @pages[i].Name
                    </li>
                }
            </ul>
        </div>
        <div class="page-card">
            <ArticleButtons StepIndex="stepIndex" MaxSteps="(pages.Count - 1)" OnChangePage="ChangePage"/>
            <div class="article-content-container">
                @if (currentPage is not null)
                {
                    @foreach (var segment in currentPage.PageSegments)
                    {
                        RenderFragment result = segment switch
                        {
                            HtmlSegment html => @<div class="article-body">@((MarkupString)html.HtmlContent)</div>,
                            SingleChoiceQuizSegment quiz => @<SingleChoiceQuiz Data="quiz" />,
                            MultipleChoiceQuizSegment multiQuiz => @<MultipleChoiceQuiz Data="multiQuiz" />,
                            FlashCardSetSegment flashCards => @<FlashCardSet Data="flashCards" />,
                            ExpandableDetailsSegment expandableDetails => @<ExpandableDetails Data="expandableDetails" />,
                            _ => @<div>Unknown segment type</div>
                        };
                        @result
                    }
                }
            </div>
            <ArticleButtons StepIndex="stepIndex" MaxSteps="(pages.Count - 1)" OnChangePage="ChangePage"/>
        </div>

        <div class="steps-container steps-right steps-container-spacer">
        </div>
    </div>
}